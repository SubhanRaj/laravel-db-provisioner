{
    "name": "subhanraj/laravel-db-provisioner",
    "description": "Automate local database and user creation with a single Artisan command for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Subhan Raj",
            "email": "shubhanraj2002@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": ">=8.0",
        "illuminate/support": ">=8.0"
    },
    "autoload": {
        "psr-4": {
            "Subhanraj\\LaravelDbProvisioner\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Subhanraj\\LaravelDbProvisioner\\LaravelDbProvisionerServiceProvider"
            ]
        }
    },
    "keywords": [
        "laravel",
        "database",
        "setup",
        "provisioning",
        "development"
    ]
}
